# Modele de configuration. Copier en .env.local (ignore par git) pour le dev.
# En production/preversion, ces valeurs viennent des Environment Variables Vercel.
# NE JAMAIS committer de vraie cle.

# Stripe — Developpeurs > Cles API (bien verifier le mode test/live en haut du dashboard)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Stripe — genere a la creation de l'endpoint webhook (phase 3).
# En local, c'est la CLI qui l'affiche : stripe listen --forward-to localhost:3000/api/stripe-webhook
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Axonaut — Dashboard > API. Pas d'environnement de test connu chez Axonaut :
# AXONAUT_ENABLED=false fait journaliser la facture au lieu de la creer reellement.
AXONAUT_API_KEY=xxx
AXONAUT_ENABLED=false

# Emails transactionnels — Resend (https://resend.com/api-keys)
# Sans cette cle : mode journal, aucun email envoye (le webhook n'echoue pas pour autant).
RESEND_API_KEY=re_xxx

# Expediteur. Avant verification d'un domaine dans Resend, garder onboarding@resend.dev
# (n'envoie qu'a l'adresse du compte Resend). Une fois oxo-spa.com verifie :
# EMAIL_FROM="OXO Spa <commande@oxo-spa.com>"
EMAIL_FROM=OXO Spa <onboarding@resend.dev>

# Destinataire de la notification interne de nouvelle commande
ORDER_NOTIFY_EMAIL=contact@oxospa.fr

# Meta Conversions API (envoi serveur des events Purchase/Lead, en plus du Pixel)
# Token : Events Manager > dataset oxo-spa-site-internet > Parametres > Conversions API.
# ⚠️ A ne renseigner QUE dans le scope Production Vercel : en Preview (Stripe test),
# le Purchase serveur est deja bloque par pi.livemode, mais autant ne pas exposer le
# token. Sans ce token, tout le serveur CAPI se met en veille (aucun envoi).
META_CAPI_TOKEN=
# Optionnel : par defaut le Pixel 1655275805769277 ("oxo-spa-site-internet").
META_DATASET_ID=
# Optionnel : pour verifier dans Events Manager > Test Events (code EVENT_xxx).
META_TEST_EVENT_CODE=
# Optionnel : version de l'API Graph (defaut v21.0).
META_GRAPH_VERSION=
